@page "/examples/custom"
@using ToastBlazor.Enums
@using ToastBlazor.Models

@inject IToastService Toast

<div class="d-flex align-items-center mb-3">
    <a href="/" class="btn btn-outline-secondary me-3">← Home</a>
    <h2 class="m-0">Custom Toasts</h2>
</div>

<button class="btn" @onclick="@ShowCustom">Custom Toast</button>
<button class="btn" @onclick="@ShowCustomIcon">Custom Icon</button>
<button class="btn" @onclick="@ShowNoProgressBar">No Progress Bar</button>

@code {
    void ShowCustom()
    {
        Toast.Show(new ToastMessage
        {
            Message = "Custom animation + dark theme",
            Level = ToastLevel.Info,
            Theme = ToastTheme.Dark,
            Animation = ToastAnimation.Zoom,
            Duration = 5000,
        });
    }

    void ShowCustomIcon()
    {
        const string StarIcon = @"
<svg viewBox='0 0 24 24' width='20' height='20' fill='currentColor'>
    <path d='M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z'/>
</svg>";
        Toast.Show("Custom animation",
            ToastLevel.Info,
            5000,
            StarIcon
        );
    }

    void ShowNoProgressBar()
    {
        Toast.Show(new ToastMessage
        {
            Message = "No Progress bar",
            Level = ToastLevel.Info,
            Theme = ToastTheme.Dark,
            Animation = ToastAnimation.Fade,
            Duration = 5000,
            ShowProgressBar = false,
        });
    }
}
